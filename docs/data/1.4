        'ต้นทุนสูงมากที่สุด เพราะต้องใช้สายสัญญาณจำนวนมหาศาล',
        'การติดตั้งและตั้งค่าซับซ้อนมาก',
        'จัดการเครือข่ายได้ยากเมื่อขยายขนาด'
      ],
      useCase: 'เครือข่ายอินเทอร์เน็ตระดับโลก (WAN), เครือข่ายทางการทหาร, หรือการเชื่อมต่อระหว่าง Core Router ในศูนย์ข้อมูล'
    },
    Hybrid: {
      name: 'แบบผสม (Hybrid Topology)',
      icon: <GitMerge className="w-6 h-6" />,
      color: 'rose',
      theme: 'from-rose-500 to-pink-500',
      bgLight: 'bg-rose-50',
      textLight: 'text-rose-700',
      borderLight: 'border-rose-200',
      desc: 'เป็นการนำรูปแบบการเชื่อมต่อ (Topology) ตั้งแต่ 2 รูปแบบขึ้นไปมาผสมผสานกัน เช่น นำเครือข่ายแบบ Star หลายๆ วงมาเชื่อมต่อกันด้วยสายแกนหลักแบบ Bus (Tree Topology)',
      pros: [
        'มีความยืดหยุ่นสูง สามารถออกแบบให้เข้ากับโครงสร้างองค์กรได้',
        'รองรับการขยายเครือข่ายขนาดใหญ่ (Scalability) ได้ดี',
        'ดึงข้อดีของแต่ละ Topology มาใช้งานร่วมกันได้'
      ],
      cons: [
        'มีความซับซ้อนในการจัดการและการบำรุงรักษา',
        'อาจมีต้นทุนสูงขึ้นอยู่กับอุปกรณ์และรูปแบบที่เลือกใช้'
      ],
      useCase: 'เครือข่ายในองค์กรขนาดใหญ่, มหาวิทยาลัย ที่มีหลายอาคารและหลายแผนกย่อย'
    }
  };

  const activeData = topologiesData[activeTopology];

  return (
    <div className="min-h-screen bg-slate-50 font-sans text-slate-800 pb-20 relative overflow-hidden">
      <CustomStyles />
      
      {/* Background Decor */}
      <div className="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-100 rounded-full mix-blend-multiply filter blur-[100px] opacity-50 pointer-events-none -z-10"></div>
      <div className="absolute bottom-0 left-0 w-[600px] h-[600px] bg-purple-100 rounded-full mix-blend-multiply filter blur-[100px] opacity-40 pointer-events-none -z-10"></div>

      {/* Header */}
      <header className="bg-slate-900 text-white py-16 px-6 relative overflow-hidden">
        <div className="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30"></div>
        <div className="max-w-6xl mx-auto relative z-10 flex flex-col md:flex-row items-center gap-6">
          <div className="w-16 h-16 bg-blue-500/20 border border-blue-400/50 rounded-2xl flex items-center justify-center backdrop-blur-sm">
            <Network className="w-8 h-8 text-blue-300" />
          </div>
          <div>
            <p className="text-blue-300 font-semibold tracking-wider mb-2 text-sm uppercase">Unit 1.4 : รูปแบบการเชื่อมต่อ</p>
            <h1 className="text-3xl md:text-5xl font-extrabold mb-3">โทโพโลยีเครือข่าย (Network Topology)</h1>
            <p className="text-lg text-slate-300 max-w-3xl leading-relaxed">
              การจัดวางผังเชิงตรรกะและกายภาพของอุปกรณ์ในระบบเครือข่าย เรียนรู้ข้อดี ข้อเสีย และเลือกใช้งานรูปแบบ Bus, Star, Ring, Mesh และ Hybrid ให้เหมาะสมกับองค์กร
            </p>
          </div>
        </div>
      </header>

      <main className="max-w-6xl mx-auto px-4 sm:px-6 -mt-8 relative z-20">
        
        {/* Topology Selector Menu */}
        <div className="flex flex-wrap justify-center gap-2 sm:gap-4 mb-10">
          {Object.keys(topologiesData).map((key) => {
            const data = topologiesData[key];
            const isActive = activeTopology === key;
            return (
              <button
                key={key}
                onClick={() => handleTopologyChange(key)}
                className={`relative px-4 sm:px-6 py-3 sm:py-4 rounded-xl flex items-center gap-3 transition-all duration-300 font-bold overflow-hidden shadow-sm
                  ${isActive 
                    ? `text-white scale-105 shadow-lg shadow-${data.color}-500/30 ring-2 ring-${data.color}-400 ring-offset-2 ring-offset-slate-50` 
                    : 'bg-white text-slate-600 hover:bg-slate-100 hover:text-slate-900 border border-slate-200'
                  }`}
              >
                {isActive && (
                  <div className={`absolute inset-0 bg-gradient-to-r ${data.theme} opacity-100`}></div>
                )}
                <div className={`relative z-10 ${isActive ? 'text-white' : `text-${data.color}-500`}`}>
                  {data.icon}
                </div>
                <span className="relative z-10 hidden sm:inline">{key}</span>
              </button>
            )
          })}
        </div>

        {/* Main Content Area */}
        <div className="glass-panel rounded-3xl p-6 sm:p-10 border border-slate-200">
          <div className={`transition-all duration-300 transform ${isTransitioning ? 'opacity-0 translate-y-4' : 'opacity-100 translate-y-0'}`}>
            
            <div className="grid lg:grid-cols-2 gap-10">
              
              {/* Left Column: Visual Simulator */}
              <div className="flex flex-col gap-6">
                <div>
                  <h2 className={`text-3xl font-extrabold mb-3 text-${activeData.color}-600 flex items-center gap-3`}>
                    {activeData.icon} {activeData.name}
                  </h2>
                  <p className="text-slate-600 leading-relaxed text-lg bg-white/50 p-4 rounded-2xl border border-slate-100">
                    {activeData.desc}
                  </p>
                </div>

                <div className="flex-grow flex flex-col justify-center">
                  <TopologySimulator type={activeTopology} />
                </div>

                {/* Use Case Badge */}
                <div className={`mt-2 p-4 rounded-2xl border ${activeData.bgLight} ${activeData.borderLight}`}>
                  <h4 className={`text-xs font-bold uppercase tracking-wider mb-2 flex items-center gap-2 ${activeData.textLight}`}>
                    <Zap className="w-4 h-4" /> ความเหมาะสมในการนำไปใช้งาน
                  </h4>
                  <p className="text-slate-800 text-sm font-medium leading-relaxed">
                    {activeData.useCase}
                  </p>
                </div>
              </div>

              {/* Right Column: Pros and Cons */}
              <div className="flex flex-col gap-6">
                
                {/* Pros Section */}
                <div className="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm flex-1">
                  <div className="flex items-center gap-3 mb-6 pb-4 border-b border-slate-100">
                    <div className="w-10 h-10 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center">
                      <CheckCircle2 className="w-6 h-6" />
                    </div>
                    <h3 className="text-xl font-bold text-slate-800">ข้อดี (Advantages)</h3>
                  </div>
                  <ul className="space-y-4">
                    {activeData.pros.map((pro, index) => (
                      <li key={index} className="flex items-start gap-3 text-slate-600">
                        <span className="text-emerald-500 mt-1 font-bold">✓</span>
                        <span className="leading-relaxed">{pro}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                {/* Cons Section */}
                <div className="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm flex-1">
                  <div className="flex items-center gap-3 mb-6 pb-4 border-b border-slate-100">
                    <div className="w-10 h-10 rounded-full bg-rose-100 text-rose-600 flex items-center justify-center">
                      <AlertTriangle className="w-6 h-6" />
                    </div>
                    <h3 className="text-xl font-bold text-slate-800">ข้อจำกัด (Disadvantages)</h3>
                  </div>
                  <ul className="space-y-4">
                    {activeData.cons.map((con, index) => (
                      <li key={index} className="flex items-start gap-3 text-slate-600">
                        <span className="text-rose-500 mt-1 font-bold">×</span>
                        <span className="leading-relaxed">{con}</span>
                      </li>
                    ))}
                  </ul>
                </div>

              </div>

            </div>
          </div>
        </div>
        
        {/* Concept Notice */}
        <div className="mt-8 flex items-start gap-3 p-4 bg-slate-800 text-slate-300 rounded-2xl text-sm max-w-4xl mx-auto shadow-lg">
          <Info className="w-5 h-5 text-blue-400 shrink-0 mt-0.5" />
          <p>
            <strong className="text-white">ข้อควรรู้:</strong> ในปัจจุบัน เครือข่ายส่วนใหญ่นิยมใช้การเชื่อมต่อทางกายภาพแบบดาว <strong className="text-blue-300">(Physical Star)</strong> แต่ในทางตรรกะอาจทำงานเป็นบัส <strong className="text-blue-300">(Logical Bus)</strong> หากใช้อุปกรณ์ Hub แบบดั้งเดิม ดังนั้นการเลือกใช้อุปกรณ์ศูนย์กลางอย่าง Switch จึงมีความสำคัญมากต่อประสิทธิภาพของเครือข่าย
          </p>
        </div>

      </main>
    </div>
  );
};

export default App;